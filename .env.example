APP_NAME="Drivers Against Flock"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=https://driversagainstflock.test
SEO_SITE_NAME="Drivers Against Flock"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=driversagainstflock
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_SITE_NAME="Drivers Against Flock"
VITE_MAPBOX_TOKEN=
VITE_GTAG_ID=

GOOGLE_PLACES_KEY=
OPENROUTESERVICE_KEY=
OPENWEBNINJA_API_KEY=
DIRECTIONS_POI_BACKEND=database
DIRECTIONS_AVOID_BUFFER_METERS=50
DIRECTIONS_MAX_DISTANCE_METERS=150000
DIRECTIONS_SEARCH_DISTANCE_MULTIPLIER=1.25
DIRECTIONS_EXPANSION_ATTEMPTS=3
DIRECTIONS_EXPANSION_MULTIPLIER=2
DIRECTIONS_CONE_ANGLE_DEGREES=45
DIRECTIONS_CONE_SEGMENTS=2
DIRECTIONS_OVERPASS_URL=https://overpass-api.de/api/interpreter

OSM2PGSQL_ENABLED=false
OSM2PGSQL_DATABASE=driversagainstflock
OSM2PGSQL_IMPORT_TABLE=osm2pgsql_alpr_nodes
OSM2PGSQL_REPLICATION_BINARY=osm2pgsql-replication
OSM2PGSQL_OSM2PGSQL_BINARY=osm2pgsql
OSM2PGSQL_STYLE=database/osm2pgsql/alpr.lua
OSM2PGSQL_REPLICATION_SERVER=https://planet.openstreetmap.org/replication/minute/
OSM2PGSQL_FLAT_NODES=
OSM2PGSQL_PROCESS_TIMEOUT_SECONDS=28800
OSM2PGSQL_SYNC_CHUNK=5000

OPENSTREETMAP_CLIENT_ID=
OPENSTREETMAP_CLIENT_SECRET=
OPENSTREETMAP_REDIRECT_URI="${APP_URL}/auth/openstreetmap/callback"
OPENSTREETMAP_API_URL=https://api06.dev.openstreetmap.org/api/0.6
MOBILE_AUTH_REDIRECT_SCHEMES=driversagainstflock
MOBILE_AUTH_CODE_EXPIRES_MINUTES=5
