{
  "name": "driversagainstflock",
  "version": "2.6.0",
  "main": "index.js",
  "expo": {
    "autolinking": {
      "ios": {
        "exclude": [
          "expo-file-system",
          "expo-image"
        ]
      }
    }
  },
  "scripts": {
    "postinstall": "patch-package",
    "start": "expo start",
    "prebuild": "expo prebuild --clean",
    "prebuild:staging": "APP_ENV=staging EXPO_NO_DOTENV=1 npx dotenv -c staging -- expo prebuild --clean",
    "prebuild:production": "APP_ENV=production EXPO_NO_DOTENV=1 npx dotenv -c production -- expo prebuild --clean",
    "build:android:staging": "APP_ENV=staging EXPO_NO_DOTENV=1 npx dotenv -c staging -- ./scripts/eas-local-build.sh -p android --profile staging --no-wait",
    "build:android:production": "APP_ENV=production EXPO_NO_DOTENV=1 npx dotenv -c production -- ./scripts/eas-local-build.sh -p android --profile production --non-interactive --no-wait",
    "build:ios:production": "APP_ENV=production EXPO_NO_DOTENV=1 npx dotenv -c production -- ./scripts/eas-local-build.sh -p ios --profile production --no-wait",
    "sentry:upload-sourcemaps": "sentry-expo-upload-sourcemaps dist",
    "android": "expo run:android",
    "android:auto": "adb forward tcp:5277 tcp:5277 && \"$ANDROID_HOME/extras/google/auto/desktop-head-unit\" -c ./config/android-auto-dhu.ini",
    "android:no-bundler": "expo run:android --no-bundler",
    "ios": "expo run:ios",
    "ios:no-bundler": "expo run:ios --no-bundler --device",
    "start:metro": "expo start --dev-client",
    "export:external": "./scripts/expo-export-external.sh",
    "e2e": "./scripts/maestro-test.sh .maestro",
    "e2e-reset": "./scripts/reset-android-location.sh",
    "test:unit": "node --test lib/osm/__tests__/*.test.mjs components/map/__tests__/*.test.mjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-native-fontawesome": "^1.0.0",
    "@gorhom/bottom-sheet": "^5.2.10",
    "@iternio/react-native-auto-play": "^0.4.7",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/analytics": "^24.1.0",
    "@react-native-firebase/app": "^24.1.0",
    "@react-navigation/drawer": "^7.9.4",
    "@rnmapbox/maps": "10.3.0",
    "@rnmapbox/navigation": "file:mapbox-navigation",
    "@sentry/react-native": "~7.11.0",
    "expo": "~55.0.27",
    "expo-build-properties": "~55.0.15",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.36",
    "expo-glass-effect": "~55.0.11",
    "expo-keep-awake": "~55.0.8",
    "expo-linking": "~55.0.16",
    "expo-location": "~55.1.11",
    "expo-navigation-bar": "~55.0.14",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.15",
    "expo-speech-recognition": "^3.1.3",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.19",
    "expo-web-browser": "~55.0.17",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4"
  },
  "private": true,
  "devDependencies": {
    "babel-preset-expo": "^55.0.18",
    "dotenv-cli": "^11.0.0",
    "patch-package": "^8.0.1",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19"
  }
}
