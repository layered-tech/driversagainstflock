+
+        parameters.rejectionReason?.let { rejectionReason ->
+            logNavigationIntentRejection(
+                rejectionReason,
+                schemeClass,
+                coordinates.state,
+                parameters.queryPresent,
+                parameters.intentClass
+            )
+            return
+        }
+
+        when (parameters.intentClass) {
+            NavigationIntentClass.ADD_A_STOP -> {
