EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
EXPO_PUBLIC_OPENSTREETMAP_CLIENT_ID=

# Optional React Native Firebase web config.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_ANALYTICS_ENABLED=1

# Native service files for React Native Firebase.
FIREBASE_ANDROID_GOOGLE_SERVICES_FILE=./google-services.json
FIREBASE_IOS_GOOGLE_SERVICES_FILE=./GoogleService-Info.plist

# Public Sentry browser/client DSN. Safe to ship in the app bundle.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENABLED=1
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
EXPO_PUBLIC_SENTRY_DEBUG=0

# Local build/source-map upload settings. Do not commit real token values.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=https://sentry.io/
