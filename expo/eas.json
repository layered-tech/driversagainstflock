{
    "cli": {
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "environment": "development",
            "env": {
                "APP_ENV": "development"
            },
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            }
        },
        "e2e-test": {
            "withoutCredentials": true,
            "environment": "development",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            }
        },
        "staging": {
            "autoIncrement": true,
            "distribution": "internal",
            "environment": "preview",
            "env": {
                "APP_ENV": "staging"
            },
            "android": {
                "buildType": "app-bundle"
            }
        },
        "production": {
            "autoIncrement": true,
            "environment": "production",
            "env": {
                "APP_ENV": "production"
            },
            "android": {
                "buildType": "app-bundle"
            }
        },
        "production-apk": {
            "autoIncrement": true,
            "environment": "production",
            "env": {
                "APP_ENV": "production"
            },
            "android": {
                "buildType": "apk"
            }
        }
    },
    "submit": {
        "testing": {
