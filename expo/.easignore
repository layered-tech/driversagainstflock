# Keep this in sync with .gitignore. EAS uses .easignore instead of .gitignore
# when creating the build archive.
#
# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
.idea/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
google-services*.json
GoogleService-Info*.plist

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env.staging
.env.production

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
/build-*

*-google-services.json
*-GoogleService-Info.plist
*-service-account-*.json

# Required by the native Firebase config plugins, but intentionally untracked.
!*-google-services.json
!*-GoogleService-Info.plist
!*-service-account-*.json
